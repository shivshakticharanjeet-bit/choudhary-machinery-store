{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A screw or machine available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "description": { "type": "string", "description": "Detailed description" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "enum": ["screw", "machine"], "description": "Product category" },
        "imageUrl": { "type": "string", "description": "URL to product image" },
        "specs": { "type": "object", "description": "Key-value pairs of technical specifications" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["name", "description", "price", "category", "imageUrl", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A customer contact request",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "message": { "type": "string", "description": "Customer message" },
        "productId": { "type": "string", "description": "Optional ID of the product they are interested in" },
        "createdAt": { "type": "number", "description": "Timestamp of inquiry" }
      },
      "required": ["name", "email", "phone", "message", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of customer inquiries"
    }
  }
}
